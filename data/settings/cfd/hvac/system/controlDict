FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application       buoyantPimpleFoam;
startFrom         latestTime;
startTime         0;
stopAt            endTime;
endTime           0.2;
deltaT            0.1;
writeControl      timeStep;
writeInterval     1;
adjustTimeStep    no;
maxCo             1;
purgeWrite        0;
writeFormat       ascii;
writePrecision    6;
writeCompression  off;
timeFormat        general;
timePrecision     6;
runTimeModifiable false;

functions
{
    // Generate VTK file with all fields at end of simulation
    writeVTK
    {
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    writeTime;
        writeInterval   1;
        
        surfaceFormat   vtk;
        fields          (T U p p_rgh PMV PPD);
        
        interpolationScheme cellPoint;
        
        surfaces
        {
            internalMesh
            {
                type            patch;
                patches         (floor ceiling);
                interpolate     true;
            }
        }
    }
}
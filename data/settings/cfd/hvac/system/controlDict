FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application       buoyantSimpleFoam;
startFrom         latestTime;
startTime         0;
stopAt            endTime;
endTime           5;
deltaT            1;
writeControl      timeStep;
writeInterval     5;
purgeWrite        0;
writeFormat       ascii;
writePrecision    6;
writeCompression  off;
timeFormat        general;
timePrecision     6;
runTimeModifiable false;

functions
{
    #include "FOage"
    #include "FOcomfort"
}
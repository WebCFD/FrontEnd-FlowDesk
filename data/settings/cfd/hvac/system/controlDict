FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application       buoyantSimpleFoam;
startFrom         startTime;
startTime         0;
stopAt            endTime;
endTime           3;
deltaT            1;
writeControl      timeStep;
writeInterval     1;  // DEBUG: Write every iteration to capture fields before crash
adjustTimeStep    no;
purgeWrite        0;
writeFormat       ascii;
writePrecision    6;
writeCompression  off;
timeFormat        general;
timePrecision     6;
runTimeModifiable false;

functions
{
    // DEBUG: Write VTK every iteration to capture fields before crash
    writeVTK
    {
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    timeStep;  // Write every timestep
        writeInterval   1;         // Every iteration
        
        surfaceFormat   vtk;
        fields          (h T U p p_rgh);  // Include T for debugging
        
        interpolationScheme cellPoint;
        
        surfaces
        {
            internalMesh
            {
                type            patch;
                patches         (floor ceiling);
                interpolate     true;
            }
        }
    }
}
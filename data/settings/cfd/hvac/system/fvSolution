FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "rho.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.1;
    }

    p_rgh
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0.01;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "(U|e|h|k|epsilon|omega)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-7;
        relTol          0.1;
    }

    "(U|e|h|k|epsilon|omega)Final"
    {
        $U;
        relTol          0;
    }

    age
    {
        $U;
        relTol          0.001;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 3;
    consistent          yes;
    pRefCell            0;
    pRefValue           0;
    
    residualControl
    {
        p_rgh           1e-4;
        U               1e-4;
        h               1e-4;
        e               1e-4;
    }
    
    // Prevent negative internal energy (e > 0) - critical for eConst thermo
    eMin                100000;   // ~-110°C safety limit (never reached in HVAC)
}

relaxationFactors
{
    fields
    {
        rho             0.005; // Extreme conservative (halved from 0.01) - Nov 1, 2025
        p_rgh           0.1;   // Halved from 0.2
    }
    equations
    {
        U               0.15;  // Halved from 0.3
        e               0.05;  // Extreme conservative (halved from 0.1) - Nov 1, 2025
        h               0.15;  // Halved from 0.3
        "(k|epsilon|omega)" 0.25; // Halved from 0.5
    }
}



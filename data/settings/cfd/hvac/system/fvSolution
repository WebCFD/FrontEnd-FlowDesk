FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "rho.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.1;
    }

    p_rgh
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0.01;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "(U|h|k|epsilon|omega)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-7;
        relTol          0.1;
    }

    "(U|h|k|epsilon|omega)Final"
    {
        $U;
        relTol          0;
    }

    age
    {
        $U;
        relTol          0.001;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 1;
    pRefCell            0;
    pRefValue           0;
    
    // Density limits to prevent Boussinesq instability
    rhoMin              0.5;
    rhoMax              2.0;
    
    // Enthalpy limits to prevent extreme temperatures
    hMin                -500000;    // ~-200K offset from Tref
    hMax                500000;     // ~+200K offset from Tref
    
    residualControl
    {
        p_rgh           1e-4;
        U               1e-4;
        h               1e-4;
    }
}

relaxationFactors
{
    fields
    {
        rho             0.1;     // Very conservative for Boussinesq stability (was 0.5)
        p_rgh           0.2;     // Reduced from 0.3 for stability
    }
    equations
    {
        U               0.5;     // Reduced from 0.7 for stability
        h               0.5;     // Reduced from 0.7 for stability (critical for Boussinesq)
        "(k|epsilon|omega)" 0.5; // Reduced from 0.7 for consistency
    }
}



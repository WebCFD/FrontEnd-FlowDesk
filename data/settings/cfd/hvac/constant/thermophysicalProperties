FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          eConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleInternalEnergy;
}

mixture
{
    specie
    {
        molWeight       28.9;
    }
    thermodynamics
    {
        Cv              718;
        Hf              0;
        Tlow            200;    // Lower temperature limit [K] ~-73°C (HVAC safety)
        Thigh           400;    // Upper temperature limit [K] ~127°C (above max HVAC)
    }
    transport
    {
        mu              1.81e-05;
        Pr              0.7;
    }
}
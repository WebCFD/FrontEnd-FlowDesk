FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    Phi
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.01;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }

    "rho.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.1;
    }

    p_rgh
    {
        solver              GAMG;
        tolerance           1e-06;
        relTol              0.01;
        smoother            DICGaussSeidel;
        cacheAgglomeration  true;
        nCellsInCoarsestLevel 10;
        agglomerator        faceAreaPair;
        mergeLevels         1;
        nPreSweeps          1;        // Aumentado 0→1 para más trabajo por iteración
        nPostSweeps         3;        // Aumentado 2→3
        nFinestSweeps       3;        // Aumentado 2→3
        minIter             4;        // Aumentado 3→4
        maxIter             200;
        
        // Pressure limits (kinematic units [m²/s²] for incompressible)
        // ±40000 Pa / 1.2 kg/m³ = ±33333 m²/s²
        pMin                -33333;   // -40000 Pa in kinematic pressure
        pMax                33333;    // +40000 Pa in kinematic pressure
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "(U|T)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-7;
        relTol          0.1;
    }

    "(U|T)Final"
    {
        $U;
        relTol          0;
    }
    
    "(k|omega)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-7;
        relTol          0.1;
    }

    "(k|omega)Final"
    {
        $k;
        relTol          0;
    }

    CO2
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.01;
        minIter         1;
        maxIter         50;
    }

    "G.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-6;
        relTol          0.01;
        maxIter         100;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 6;  // Increased to 6 for maximum pressure-velocity coupling
    consistent          yes;
    pRefCell            0;
    pRefValue           0;  // Gauge pressure reference (p = p_rgh + g·h)
    
    residualControl
    {
        p_rgh           1e-4;
        U               1e-4;
        T               1e-4;
        k               1e-4;
        omega           1e-4;
    }
}

relaxationFactors
{
    fields
    {
        p_rgh           0.08;  // Maximum conservatism for p_rgh convergence
    }
    equations
    {
        U               0.25;  // Extreme stability for strong buoyancy
        T               0.35;  // Extreme stability for thermal coupling
        "(k|omega)"     0.5;   // Turbulence model stability
        CO2             0.7;   // Conservadurismo scalar transport para evitar undershoots
        G               0.3;   // Under-relaxation for radiation convergence
    }
}



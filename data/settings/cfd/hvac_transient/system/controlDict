FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application       buoyantBoussinesqPimpleFoam;
startFrom         startTime;
startTime         0;
stopAt            endTime;
endTime           5000;
deltaT            1;
writeControl      timeStep;    // Write by iteration number
writeInterval     500;          // Write only at final iteration
adjustTimeStep    no;
purgeWrite        0;            // Keep all timesteps (0 and 500)
writeFormat       ascii;
writePrecision    6;
writeCompression  off;
timeFormat        general;
timePrecision     6;
runTimeModifiable true;         // Enable runtime modification for immediate writes

// Placeholder for mass flow monitoring functions (auto-generated by pipeline)
// massFlow functions will be inserted here by hvac.py during case setup

functions
{
    CO2transport
    {
        type            scalarTransport;
        libs            ("libsolverFunctionObjects.so");
        
        field           CO2;
        
        // Difusividad CO2 en aire a 20°C: 1.6e-5 m²/s
        D               1.6e-5;
        
        // Convección activada (usa campo U del solver)
        diffusion       yes;
        
        // NO reiniciar en cada timestep
        resetOnStartUp  false;
        
        // Escribir CO2 cuando solver escribe (cada writeInterval)
        executeControl  timeStep;
        executeInterval 1;
        writeControl    writeTime;
    }
    
    limitCO2
    {
        type            limitFields;
        libs            ("libfieldFunctionObjects.so");
        
        // Clipar CO2 entre [0,1] cada timestep para evitar overshoots numéricos
        fields          (CO2);
        limit           both;
        min             0;
        max             1;
        
        writeControl    none;
    }
}


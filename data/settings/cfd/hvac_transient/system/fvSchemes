FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         steadyState;
}

gradSchemes
{
    default         cellLimited Gauss linear 0.5;
    grad(U)         cellLimited Gauss linear 0.5;
    grad(p_rgh)     cellLimited Gauss linear 0.25;  // Ultra-conservador para convergencia p_rgh
}

divSchemes
{
    default         none;

    div(phi,U)      bounded Gauss linearUpwind grad(U);
    
    // Temperature transport (for buoyantBoussinesqSimpleFoam)
    div(phi,T)      bounded Gauss linearUpwind grad(T);
    
    // Turbulence model kOmegaSST
    div(phi,k)      bounded Gauss upwind;
    div(phi,omega)  bounded Gauss upwind;
    
    div(phi,K)      bounded Gauss upwind;

    // Laminar stress tensor (for Boussinesq)
    div((nuEff*dev2(T(grad(U)))))   Gauss linear;
    
    // Scalar transport (CO2) - upwind puro para máxima estabilidad [0,1]
    div(phi,CO2)    bounded Gauss upwind;
    
    // Radiation P1 model
    div(phi,G)      bounded Gauss upwind;
}

laplacianSchemes
{
    default         Gauss linear limited 0.5;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         limited 0.5;
}

wallDist
{
    method meshWave;
}



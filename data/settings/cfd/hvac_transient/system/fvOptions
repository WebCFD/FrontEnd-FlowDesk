// ============================================================================
// PHYSICAL LIMITS FOR SOLUTION STABILITY (OpenFOAM v2412 ESI format)
// ============================================================================
// These limits prevent non-physical values that can cause divergence
// and ensure solutions remain within realistic HVAC operating ranges
// ============================================================================

limitU
{
    type            limitVelocity;
    active          yes;
    selectionMode   all;
    
    // VELOCITY LIMIT: 20 m/s maximum magnitude
    // Physical context:
    // - Typical HVAC: 0.5-5 m/s
    // - High velocity diffusers: up to 10-15 m/s
    // - 20 m/s conservative safety margin
    max             20;  // m/s
}

// NOTE: limitTemperature removed - incompatible with buoyantBoussinesqSimpleFoam
// This solver doesn't use thermophysicalProperties in the required format
// Temperature is handled directly via T field with boundary conditions

// NOTE: limitG removed - limitTemperature requires thermophysicalProperties
// which is incompatible with buoyantBoussinesqSimpleFoam
// Solution: Initialize G=100 (not zero) to prevent matrix singularity
// GAMG solver + relaxation (G=0.7) provide sufficient numerical stability

// ============================================================================
// MEAN AGE OF AIR SOURCE TERM
// ============================================================================
// Implements the Sandberg (1981) steady-state Mean Age of Air equation:
//   ∇·(U·τ) - ∇·(D_eff·∇τ) = 1   [s/s]
//
// The source term S=1 means every fluid parcel ages 1 second per second.
// Inlets impose τ=0 (fresh air). The field τ [s] gives the local residence
// time of air directly — no post-processing estimation needed.
// ============================================================================

ageSource
{
    type            scalarSemiImplicitSource;
    active          yes;

    scalarSemiImplicitSourceCoeffs
    {
        selectionMode   all;        // OpenFOAM 2412: must be inside coeffs subdict
        // volumeMode specific: source = Su * volume → integrates to 1 [s/s] per m³
        volumeMode      specific;
        injectionRateSuSp
        {
            age     (1.0    0);     // Su=1 [s/s], Sp=0 (explicit, always positive)
        }
    }
}



FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       false;
overwrite       true;

geometry
{
    $STL_FILENAME
    {
        type triSurfaceMesh;
        file $STL_FILENAME;
		name geometry;
        tolerance   1E-5;
        maxTreeDepth 10;

		$GEOMETRY_REGIONS
    }
};

castellatedMeshControls
{
    maxLocalCells 100000;
    maxGlobalCells 2000000;
    minRefinementCells 2;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 1;


    features
    ( 
        {
            file $EMESH_FILENAME;
			levels ((0.002 2) (0.010 1));
        }
    );

    refinementSurfaces
    {
		geometry
		{
			level (0 1);
			$REFINEMENT_SURFACES
		}
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
    }

    locationInMesh $LOCATION_INSIDE_MESH;
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 3;
    tolerance 2.0;
    nSolveIter 30;
    nRelaxIter 5;

        nFeatureSnapIter 10;
        implicitFeatureSnap false;
        explicitFeatureSnap true;
        multiRegionFeatureSnap false;
}

addLayersControls
{
    relativeSizes true;
	
    expansionRatio 1.0;
    thickness 0.010;
    minThickness 0.005;

    layers
    {
        sphere.stl_firstSolid
        {
            nSurfaceLayers 1;

        }
        maxY
        {
            nSurfaceLayers 1;
            expansionRatio      1.3;
            finalLayerThickness 0.3;
            minThickness        0.1;
        }
		
        frozenPatches
        {
            nSurfaceLayers 0;
        }
    }
	
    nGrow 0;
    featureAngle 60;
    slipFeatureAngle 30;
    nRelaxIter 5;
    nSmoothSurfaceNormals 1;
    nSmoothNormals 3;
    nSmoothThickness 10;
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.3;
    minMedianAxisAngle 90;
    nBufferCellsNoExtrude 0;
    nLayerIter 50;
    nRelaxedIter 20;
}

meshQualityControls
{
    maxNonOrtho 65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    maxConcave 80;
    minVol 1e-13;
    minTetQuality 1e-9;
    minArea -1;
    minTwist 0.05;
    minDeterminant 0.001;
    minFaceWeight 0.05;
    minVolRatio 0.01;
    minTriangleTwist -1;

    nSmoothScale 4;
    errorReduction 0.75;

    relaxed
    {
        maxNonOrtho 75;
    }
}

debug 0;

mergeTolerance 1e-6;
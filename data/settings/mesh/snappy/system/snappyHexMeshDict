FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       $ENABLE_LAYERS;
overwrite       true;

geometry
{
    $STL_FILENAME
    {
        type triSurfaceMesh;
        file $STL_FILENAME;
                name geometry;
        tolerance   1E-5;
        maxTreeDepth 10;

                $GEOMETRY_REGIONS
    }
};

castellatedMeshControls
{
    maxLocalCells 100000;
    maxGlobalCells 2000000;
    minRefinementCells 2;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 1;


    features
    ( 
        {
            file $EMESH_FILENAME;
                        levels ((0.002 2) (0.010 1));
        }
    );

    refinementSurfaces
    {
                geometry
                {
                        level (0 1);
                        $REFINEMENT_SURFACES
                }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
$VOLUMETRIC_REFINEMENT
    }

    locationInMesh $LOCATION_INSIDE_MESH;
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 3;
    tolerance 2.0;
    nSolveIter 30;
    nRelaxIter 5;

        nFeatureSnapIter 10;
        implicitFeatureSnap false;
        explicitFeatureSnap true;
        multiRegionFeatureSnap false;
}

addLayersControls
{
    relativeSizes true;
    
    // High-quality boundary layers for HVAC applications
    layers
    {
$BOUNDARY_LAYERS
    }
    
    // Improved layer generation settings for better coverage
    nGrow 0;
    featureAngle 70;              // Increased to allow layers on more surfaces
    slipFeatureAngle 30;
    nRelaxIter 10;                // More relaxation iterations
    nSmoothSurfaceNormals 3;      // Smoother surface normals
    nSmoothNormals 5;             // More normal smoothing
    nSmoothThickness 15;          // More thickness smoothing
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.5; // Relaxed for better coverage
    minThickness 0.1;             // Relative minimum (10% of cell size)
    minMedianAxisAngle 85;        // Relaxed to allow more layers
    nBufferCellsNoExtrude 0;
    nLayerIter 100;               // More iterations for better quality
    nRelaxedIter 50;              // More relaxed iterations
    
    // Advanced settings for robust layer generation
    additionalReporting true;
    mergePatchFacesAngle 45;
}

meshQualityControls
{
    // Strict quality controls for high-quality HVAC mesh
    maxNonOrtho 60;               // Tighter than default (65) for better quality
    maxBoundarySkewness 15;       // Tighter than default (20)
    maxInternalSkewness 3;        // Tighter than default (4)
    maxConcave 75;                // Slightly tighter
    minVol 1e-15;                 // Allow smaller cells near boundaries
    minTetQuality 1e-12;          // Stricter tetrahedral quality
    minArea 1e-15;                // Allow smaller faces
    minTwist 0.02;                // Stricter twist requirement
    minDeterminant 0.005;         // Relaxed slightly for complex geometries
    minFaceWeight 0.02;           // Tighter face weight
    minVolRatio 0.005;            // Tighter volume ratio
    minTriangleTwist -1;

    nSmoothScale 6;               // More smoothing iterations
    errorReduction 0.75;

    // Relaxed controls for difficult regions
    relaxed
    {
        maxNonOrtho 70;
        maxBoundarySkewness 20;
        maxInternalSkewness 4;
    }
}

debug 0;

mergeTolerance 1e-6;
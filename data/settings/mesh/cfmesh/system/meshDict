FoamFile
{
    version   2.0;
    format    ascii;
    class     dictionary;
    location  "system";
    object    meshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

surfaceFile "constant/triSurface/$FMS_FILENAME";

// Tamaños base - malla ligera
maxCellSize $MAX_CELL_SIZE;

minCellSize $MIN_CELL_SIZE;


boundaryCellSize $BOUNDARY_CELL_SIZE;


$LOCAL_REFINEMENT


$BOUNDARY_LAYERS


// Para flujo interno
//keepCellsIntersectingBoundary 1;
//checkForGluedMesh 1;




renameBoundary
{
    defaultName walls;
    defaultType wall;
}

// Mesh quality improvement: cfMesh will attempt to fix cells that violate these thresholds.
// maxNonOrthogonality triggers vertex/edge smoothing for highly skewed cells.
// minCellVolume targets near-zero and negative-volume cells (e.g. at polygon wall corners).
meshQualitySettings
{
    maxNonOrthogonality 65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    minCellVolume       1e-8;   // catches cells with V < 1e-8 m³ (incl. negative volumes)
    minFaceArea         1e-13;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
